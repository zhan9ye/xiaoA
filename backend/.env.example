# 必填：生产环境请改为强随机字符串（JWT 签名）
# JWT_SECRET=your-long-random-secret

# 是否开放自助注册（公网建议改为 false）
# REGISTRATION_OPEN=true

# 开售整点（北京时间 sell_start_time）之前多少秒开始登录并拉取子账号（默认 30）
# SELL_PREP_SECONDS_BEFORE=30
# 定时开售时：仅开售时刻起满该秒数后，才把「本日交易通道已關閉」当作真收工（默认 60，避免整点尚未开门误判）
# SELL_CHANNEL_CLOSED_TRUST_AFTER_SECONDS=60
# 定时开售准备阶段最大尝试次数（须在 T_open 前完成 Login+子账号）
# SELL_PREP_MAX_ATTEMPTS=8
# SELL_PREP_RETRY_DELAY_SECONDS=2
# WaitOpen：先睡到开售整点减该毫秒数再睡到整点
# SELL_WAIT_OPEN_WAKE_EARLY_MS=50
# 多 ECS 共用数据库时互斥 runner（单机 SQLite 可保持 false）
# RUNNER_LEASE_ENABLED=false
# RUNNER_LEASE_TTL_SECONDS=45
# RUNNER_LEASE_HOLDER_ID=
# 停止后再开始、Login 后补拉子账号：最大次数与间隔（毫秒）
# SELL_RESUME_SUB_FETCH_MAX_ATTEMPTS=6
# SELL_RESUME_SUB_FETCH_DELAY_MS=500

# 出站 httpx 写文件日志（默认 backend/logs/http_requests.log；带 platform_user_id；成功响应体省略，失败才记 body）
# REQUEST_LOG_ENABLED=true
# 逗号分隔主机名，仅匹配等于或为其子域的出站请求（默认 akapi1.com 含 www.akapi1.com）
# REQUEST_LOG_OUTBOUND_HOSTS=akapi1.com
# REQUEST_LOG_DIR=
# REQUEST_LOG_MAX_BYTES=10485760
# REQUEST_LOG_BACKUP_COUNT=5
# REQUEST_LOG_MAX_BODY=262144

# 子账号接口 URL（一般不用改）
# SUBACCOUNT_URL=https://www.akapi1.com/RPC/My_Subaccount

# 子账号分页（服务端内部使用，操作台不展示）
# SUBACCOUNT_PAGE_SIZE=15
# SUBACCOUNT_MAX_PAGES=200

# SQLite 路径（默认 backend/data/app.db）
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# 出站代理池：在库表 proxy_pool_entries 中维护；非空时用户首次 RPC 会静态绑定一条。
# 池满且无空闲节点时：true=返回 503，false=回退直连（不推荐生产）
# PROXY_POOL_REQUIRE_AVAILABLE=true

# 出站 HTTPS 是否校验证书（RPC 到 akapi1 等）。默认 true。若对端证书链不完整导致 CERTIFICATE_VERIFY_FAILED，可暂设 false（有中间人风险）
# OUTBOUND_TLS_VERIFY=true

# 后台管理（不入库；留空则禁用 /api/admin/*）
# 前端访问：开发环境打开 http://localhost:5173/#/admin
ADMIN_USERNAME=admin
# 推荐：仅存放 bcrypt 哈希（与平台用户密码算法一致），.env 中勿写明文
# 生成：在 backend 目录执行
#   .venv/bin/python -c "from app.auth_crypto import hash_password; print(hash_password('你的强密码'))"
# 整行建议用单引号包住（哈希含 $ 字符）
ADMIN_PASSWORD_HASH='$2b$12$vXUYHrvnFEqNSxORi/MoxeJW8O19EydZFegcfS7/q2X4z7gKYh7Uq'
# 本地调试可选用明文（生产请勿使用）
# ADMIN_PASSWORD=change-me-strong
# ADMIN_JWT_EXPIRE_HOURS=8
